# Required for the action-alignment runner (Claude Sonnet judges proposed actions)
ANTHROPIC_API_KEY=sk-ant-xxx

# Required for any benchmark using GPT-4o or GPT-4o-mini as the agent model.
# Note: OpenAI Tier 1 has a 3 RPM limit on gpt-4o that will throttle the recall-over-time runner.
# Add prepayment credits + verify Tier 2 status if you need full-speed runs.
OPENAI_API_KEY=sk-proj-xxx

# Required only for re-judge.py (cross-validates Sonnet scores with Gemini-2.5-flash).
# Billing must be enabled at https://ai.studio/projects before this works.
GOOGLE_API_KEY=AIzaSy-xxx
