{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": ["runners/**/*.ts"],
  "exclude": ["node_modules", "dist", "fixtures"]
}
