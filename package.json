{
  "name": "continuity-benchmarks",
  "version": "2.0.0",
  "description": "Reproducible benchmarks for structured-knowledge-graph retrieval in long-horizon AI agents — v6.4/v7.5 walkback edition with v2 cross-corpus matrix + M2 timing ablation + n=1,620 inter-judge replication",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "test:smoke": "ts-node --transpile-only runners/recall-over-time.ts --fixture paydash-api --model mock --sessions 1 --output /tmp/smoke-recall",
    "test:smoke-v2": "ts-node --transpile-only runners/recall-over-time.ts --fixture data-pipeline --model mock --sessions 2 --conditions baseline,continuity-blanket,continuity-perq-frontloaded,continuity-in-loop --output /tmp/smoke-recall-v2",
    "test:smoke-alignment": "ts-node --transpile-only runners/action-alignment.ts --fixture paydash-api --model mock --actions 3 --output /tmp/smoke-alignment",
    "bench:recall": "ts-node --transpile-only runners/recall-over-time.ts",
    "bench:alignment": "ts-node --transpile-only runners/action-alignment.ts",
    "bench:convergence": "ts-node --transpile-only runners/convergence-time.ts",
    "bench:matrix-v1": "bash scripts/run-id-rag-parity.sh",
    "bench:matrix-v2": "bash scripts/run-id-rag-parity-v2.sh",
    "bench:matrix-v2-resume": "bash scripts/run-id-rag-parity-v2-resume.sh",
    "analyze:v2": "python3 runners/experimental-gaps-analysis-v2.py",
    "bootstrap:ci": "python3 runners/bootstrap-ci.py",
    "bench:head-to-head": "tsx runners/head-to-head.ts",
    "bench:middleware-replay": "tsx runners/middleware-replay.ts",
    "test:smoke-middleware-replay": "tsx runners/middleware-replay.ts --fixture data-pipeline --model mock --questions 2 --retrieval=mcp-search --output /tmp/smoke-mw-replay",
    "rejudge:paydash": "python3 runners/re-judge.py",
    "rejudge:cross-corpus": "python3 runners/re-judge-cross-corpus.py"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.2.3",
    "tiktoken": "^1.0.22",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
